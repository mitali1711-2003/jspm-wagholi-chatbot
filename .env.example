# Required — Flask session encryption key (generate a random string)
SECRET_KEY=

# Required for create_admin.py — password for the admin user
ADMIN_PASSWORD=

# Optional — server port (auto-set by Railway/Render)
PORT=5000

# Optional — set to 1 to use cached HuggingFace model (no network calls)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
